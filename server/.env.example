# Copia este archivo a ".env" y rellena tus credenciales.
# (El servidor carga .env automáticamente al arrancar.)

PORT=3000

# Cada cuántos minutos revisar puntuación de tormentas (granizo, viento, lluvia, densidad)
POLL_MINUTES=10

# Correo que recibirá alertas cuando score ≥ ALERT_MIN_SCORE
ALERT_TO=premierandmarketing@gmail.com

# Puntuación mínima para email (40=revisar manual, 70=solo alta prioridad)
ALERT_MIN_SCORE=40

# No re-notificar la misma zona si ya avisó en las últimas N horas
ALERT_COOLDOWN_HOURS=72

# Jobs mínimos en radio de tormenta para +20 pts (alta densidad viviendas)
HOME_DENSITY_MIN=5

# Caché de jobs JobNimbus para el monitor de tormentas (minutos)
JN_SCORE_CACHE_MIN=20

# Máximo de eventos en historial (archivo JSON, sin base de datos)
STORM_HISTORY_MAX=500
# Conservar eventos como máximo N días (0 = sin límite por fecha, solo por cantidad)
STORM_HISTORY_RETENTION_DAYS=365

# --- Acceso equipo Premier Sky (login por código) ---
# Emails del Team JobNimbus (Settings → Admin → Team), separados por coma.
# Usa el mismo correo con el que cada persona entra a JobNimbus.
PREMIER_TEAM_EMAILS=sky@premierchi.com
# Alternativa: permitir cualquier email de estos dominios
# PREMIER_EMAIL_DOMAINS=premierchi.com
SESSION_HOURS=3
# En local sin HTTPS: COOKIE_SECURE=false
COOKIE_SECURE=false
# Solo desarrollo: AUTH_DISABLED=true desactiva el login
# AUTH_DISABLED=true

# --- SMTP (códigos de acceso + alertas) ---
# Premier: mail.premierchi.com · puerto 465 · SSL
SMTP_HOST=mail.premierchi.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=sky@premierchi.com
SMTP_PASS=tu-contraseña-del-buzon
SMTP_FROM=Premier Sky <sky@premierchi.com>

# --- JobNimbus (CRM · jobs por zona) ---
# IMPORTANTE: API key con perfil de SOLO LECTURA + permiso de lectura de contacts.
JOBNIMBUS_API_KEY=
JOBNIMBUS_API_URL=https://app.jobnimbus.com/api1

# --- Open-Meteo (opcional · plan de pago ~$29/mes) ---
# Sin clave: usa api.open-meteo.com gratis (con límites). Con clave: customer-api.open-meteo.com
# OPEN_METEO_API_KEY=
