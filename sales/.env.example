# Copy to .env and fill in as keys become available. Everything runs without
# keys — routes fall back to free providers or clearly-marked stubs.

PORT=3000

# PENDING DECISION — Google Maps API key. Powers TWO things when set:
#  1. /api/geocode switches from free fallback (zippopotam+FCC) to Google
#  2. Google Solar API roof measurements (enable "Solar API" on the same
#     Google Cloud project) — per-building roof area, segments, and pitch
GOOGLE_MAPS_API_KEY=

# Regrid Parcel API — paid fallback for non-IL markets (FL, WI, MD, VA/DC).
# $375-500/mo Standard/Premium; 30-day free sandbox available.
REGRID_API_KEY=

# JobNimbus CRM — custom backend integration (Zapier ruled out per prior project).
# Same admin key can write contacts/tasks for Sales; Sky stays GET-only in code.
JOBNIMBUS_API_KEY=
JOBNIMBUS_API_URL=https://app.jobnimbus.com/api1
# Must match an ACTIVE contact workflow in JobNimbus (Settings → Workflows).
# Premier: Commercial/New Leads exists but is inactive — API rejects it.
# Use Customer / Active (verified). Server auto-resolves from account/settings.
JOBNIMBUS_CONTACT_TYPE=Customer
JOBNIMBUS_CONTACT_STATUS=Active
JOBNIMBUS_TASK_TYPE=Task
